{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "channel": {
      "type": "string",
      "enum": [
        "Vkontakte",
        "Telegram",
        "Email"
      ]
    },
    "confirmed_channel": {
      "type": "string",
      "enum": [
        "Vkontakte",
        "Telegram",
        "Email"
      ]
    },
    "email": {
      "type": "string"
    },
    "vkontakte": {
      "type": "string"
    },
    "telegram": {
      "type": "string"
    }
  },
  "required": [
    "channel"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "channel": { "const": "Vkontakte" }
        }
      },
      "then": {
        "required": ["vkontakte", "confirmed_channel"]
      }
    },
    {
      "if": {
        "properties": {
          "channel": { "const": "Telegram" }
        }
      },
      "then": {
        "required": ["telegram", "confirmed_channel"]
      }
    },
    {
      "if": {
        "properties": {
          "channel": { "const": "Email" }
        }
      },
      "then": {
        "required": ["email"]
      }
    }
  ]
}
