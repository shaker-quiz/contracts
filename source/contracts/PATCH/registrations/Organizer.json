{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid"
      },
      "visibility": {
        "type": "string",
        "enum": [
          "Visible",
          "Hidden"
        ]
      }
    },
    "required": [
      "id",
      "visibility"
    ],
    "additionalProperties": false
  },
  "minItems": 1
}
