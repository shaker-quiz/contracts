{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid"
      },
      "template": {
        "type": "string",
        "enum": [
          "default",
          "verified-registration-any",
          "verified-registration-cash"
        ]
      },
      "message": {
        "type": "string"
      }
    },
    "required": [
      "id",
      "template",
      "message"
    ],
    "additionalProperties": false
  },
  "uniqueItems": true
}
