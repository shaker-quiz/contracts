{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "game_id": {
      "type": "string",
      "format": "uuid"
    },
    "human_name": {
      "type": "string"
    },
    "team_name": {
      "type": "string"
    },
    "people_count": {
      "type": "integer"
    },
    "channel": {
      "type": "string",
      "enum": [
        "Vkontakte",
        "Telegram",
        "Email"
      ]
    },
    "confirmed_channel": {
      "type": "string",
      "enum": [
        "Vkontakte",
        "Telegram",
        "Email"
      ]
    },
    "email": {
      "type": "string"
    },
    "vkontakte": {
      "type": "string"
    },
    "telegram": {
      "type": "string"
    },
    "is_alone": {
      "type": "boolean"
    },
    "is_birthday": {
      "type": "boolean"
    },
    "is_extensible": {
      "type": "boolean"
    },
    "is_first": {
      "type": "boolean"
    },
    "celebrant": {
      "type": "string"
    },
    "ads_from": {
      "type": "string"
    },
    "comment": {
      "type": "string"
    },
    "phone": {
      "type": "string"
    },
    "promocode": {
      "type": "string"
    },
    "utm_campaign": {
      "type": "string"
    },
    "utm_content": {
      "type": "string"
    },
    "utm_medium": {
      "type": "string"
    },
    "utm_source": {
      "type": "string"
    },
    "utm_term": {
      "type": "string"
    }
  },
  "required": [
    "game_id",
    "human_name",
    "team_name",
    "people_count",
    "channel",
    "is_alone",
    "is_birthday",
    "is_extensible",
    "is_first"
  ],
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "channel": { "const": "Vkontakte" }
        }
      },
      "then": {
        "required": ["vkontakte", "confirmed_channel"]
      }
    },
    {
      "if": {
        "properties": {
          "channel": { "const": "Telegram" }
        }
      },
      "then": {
        "required": ["telegram", "confirmed_channel"]
      }
    },
    {
      "if": {
        "properties": {
          "channel": { "const": "Email" }
        }
      },
      "then": {
        "required": ["email"]
      }
    },
    {
      "if": {
        "properties": {
          "is_birthday": { "const": true }
        }
      },
      "then": {
        "required": ["celebrant"],
        "properties": {
          "celebrant": { "type": "string" }
        }
      }
    }
  ]
}