{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "number": {
      "type": "string"
    },
    "event_time": {
      "type": "string",
      "format": "iso-date-time"
    },
    "price": {
      "type": "number"
    },
    "min_members_count": {
      "type": "integer"
    },
    "max_members_count": {
      "type": "integer"
    },
    "status": {
      "type": "string",
      "enum": [
        "Approve",
        "Archive",
        "Close",
        "Finish",
        "Invite",
        "Reserve",
        "Moderate",
        "Publish",
        "Reject"
      ]
    },
    "visibility": {
      "type": "string",
      "enum": [
        "Visible",
        "Hidden"
      ]
    }
  },
  "required": [],
  "additionalProperties": false
}
