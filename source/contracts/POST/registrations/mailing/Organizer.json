{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid"
      },
      "feature": {
        "type": "string",
        "enum": [
          "TEXT",
          "CREATED_REGISTRATION",
          "CHANGED_REGISTRATION_STATUS",
          "CHANGED_REGISTRATION_LINEUP",
          "VERIFIED_REGISTRATION_CHANNEL"
        ]
      },
      "message": {
        "type": "string"
      },
      "payment": {
        "type": "string",
        "enum": [
          "Any",
          "Cash"
        ]
      }
    },
    "required": [
      "id",
      "feature",
      "message",
      "payment"
    ],
    "additionalProperties": false
  },
  "uniqueItems": true
}
