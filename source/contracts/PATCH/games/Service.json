{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid"
      },
      "status": {
        "type": "string",
        "enum": [
          "Approve",
          "Archive",
          "Cancel",
          "Close",
          "Finish",
          "Invite",
          "Reserve",
          "Moderate",
          "Publish",
          "Reject"
        ]
      },
      "visibility": {
        "type": "string",
        "enum": [
          "Visible",
          "Hidden"
        ]
      }
    },
    "required": [
      "id"
    ],
    "additionalProperties": false
  },
  "uniqueItems": true
}
