{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid"
      },
      "feature": {
        "type": "string",
        "enum": [
          "Text",
          "Registration/Created",
          "Registration/Restored",
          "Registration/Status/Changed",
          "Registration/Lineup/Changed",
          "Registration/Channel/Confirmed",
          "Registration/Confirmation"
        ]
      },
      "message": {
        "type": "string"
      },
      "payment": {
        "type": "string",
        "enum": [
          "Any",
          "Cash"
        ]
      }
    },
    "required": [
      "id",
      "feature",
      "message",
      "payment"
    ],
    "additionalProperties": false
  },
  "uniqueItems": true
}
