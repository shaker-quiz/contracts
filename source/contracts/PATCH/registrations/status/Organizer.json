{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "id": {
        "type": "string",
        "format": "uuid"
      },
      "procedure": {
        "type": "string",
        "enum": [
          "Assignment",
          "Confirmation",
          "Cancellation",
          "Restoration",
          "Reinstatement"
        ]
      }
    },
    "required": [
      "id",
      "procedure"
    ],
    "additionalProperties": false
  },
  "minItems": 1
}
